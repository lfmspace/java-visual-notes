    {
      "id": "N9dW6azdSuwRA2CNdFkew",
      "type": "text",
      "x": -4735.603342713663,
      "y": -390.0916942944041,
      "width": 1350.7667236328125,
      "height": 1500,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "#fff4e6",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "cI7v",
