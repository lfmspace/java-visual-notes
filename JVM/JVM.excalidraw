    {
      "id": "okLoleuMRs8juBInUVXGN",
      "type": "text",
      "x": -3140.263361657579,
      "y": 3573.275950371499,
      "width": 1036.81982421875,
      "height": 525,
      "angle": 0,
      "strokeColor": "#1e1e1e",
