      "text": "一个Lock可以对应多个Condition对象，可以为不同的等待条件创建不同的Condition，实现线程独立控制",
      "fontSize": 20,
      "fontFamily": 6,
      "textAlign": "center",
      "verticalAlign": "middle",
      "containerId": "VHzs-pLGBA6KnSI4Bu12C",
      "originalText": "一个Lock可以对应多个Condition对象，可以为不同的等待条件创建不同的Condition，实现线程独立控制",
      "autoResize": true,
      "lineHeight": 1.25
    },
