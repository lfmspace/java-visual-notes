      "isDeleted": false,
      "boundElements": [],
      "updated": 1772853188925,
      "link": null,
      "locked": false,
      "text": "ReentrantLock的应用场景主要体现在多线程环境下对共享资源的独占式访问，以保证数据的一致性和安全性。",
      "fontSize": 20,
      "fontFamily": 6,
      "textAlign": "left",
      "verticalAlign": "middle",
      "containerId": "SoEzkfIyOCaGox0ncWBCP",
      "originalText": "ReentrantLock的应用场景主要体现在多线程环境下对共享资源的独占式访问，以保证数据的一致性和安全性。",
      "autoResize": true,
      "lineHeight": 1.25
    },
