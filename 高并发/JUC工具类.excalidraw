      "text": "Phaser",
      "fontSize": 20,
      "fontFamily": 6,
      "textAlign": "center",
      "verticalAlign": "middle",
      "containerId": "N6iH6V9e6Ll3otvC8K4Ed",
      "originalText": "Phaser",
      "autoResize": true,
      "lineHeight": 1.25
    },
    {
      "id": "ULzIfMs2G5XPITE9HeQo5",
      "type": "text",
      "x": -4978.391272758154,
      "y": 757.8067099717473,
      "width": 800,
      "height": 125,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 0,
      "opacity": 100,
      "groupIds": [
        "Gk1dv3OasMuBFjmFDG9NJ"
      ],
      "frameId": null,
      "index": "cDIR",
      "roundness": null,
      "seed": 577551657,
      "version": 284,
      "versionNonce": 427356686,
      "isDeleted": false,
      "boundElements": [],
      "updated": 1772853188926,
      "link": null,
      "locked": false,
      "text": "Phaser（阶段协同器）是一个Java实现的并发工具类，用于协调多个线程的执行。它提供\n了一些方便的方法来管理多个阶段的执行，可以让程序员灵活地控制线程的执行顺序和阶段\n性的执行。Phaser可以被视为CyclicBarrier和CountDownLatch的进化版，它能够自适应地\n调整并发线程数，可以动态地增加或减少参与线程的数量。所以Phaser特别适合使用在重\n复执行或者重用的情况。",
      "fontSize": 20,
      "fontFamily": 6,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "Phaser（阶段协同器）是一个Java实现的并发工具类，用于协调多个线程的执行。它提供了一些方便的方法来管理多个阶段的执行，可以让程序员灵活地控制线程的执行顺序和阶段性的执行。Phaser可以被视为CyclicBarrier和CountDownLatch的进化版，它能够自适应地调整并发线程数，可以动态地增加或减少参与线程的数量。所以Phaser特别适合使用在重复执行或者重用的情况。",
      "autoResize": false,
      "lineHeight": 1.25
    },
