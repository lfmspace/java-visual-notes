      "isDeleted": false,
      "boundElements": [],
      "updated": 1775214283335,
      "link": null,
      "locked": false,
      "text": "- 不允许read和load、store和write操作之一单独出现",
      "fontSize": 20,
      "fontFamily": 6,
      "textAlign": "left",
      "verticalAlign": "middle",
      "containerId": "VSy61UMJOOpJQ_fvcmGn9",
      "originalText": "- 不允许read和load、store和write操作之一单独出现",
      "autoResize": true,
      "lineHeight": 1.25
    },
    {
      "id": "4lU_VJ6WDr-HVXnH5fDW_",
      "type": "rectangle",
      "x": 181.5913776959094,
      "y": 4297.948963350309,
      "width": 903.3264641395516,
      "height": 35,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "#fff9db",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 1,
