      "isDeleted": false,
      "boundElements": null,
      "updated": 1775223494622,
      "link": null,
      "locked": false,
      "text": "volatile 的写和读内存语义，影响的是本地内存中的“所有”共享变量",
      "fontSize": 20,
      "fontFamily": 6,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "volatile 的写和读内存语义，影响的是本地内存中的“所有”共享变量",
      "autoResize": true,
      "lineHeight": 1.25
    },
