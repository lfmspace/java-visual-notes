      "type": "text",
      "x": 230.87065362445605,
      "y": 6559.2839906029,
      "width": 529.759765625,
      "height": 25,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "#ffc9c9",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
