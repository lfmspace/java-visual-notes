      "isDeleted": false,
      "boundElements": [],
      "updated": 1775214283335,
      "link": null,
      "locked": false,
      "text": "2. 刷新处理器缓存",
      "fontSize": 20,
      "fontFamily": 6,
      "textAlign": "center",
      "verticalAlign": "middle",
      "containerId": "IJ6npUDMjD1eQ9fY8gOZ1",
      "originalText": "2. 刷新处理器缓存",
      "autoResize": true,
      "lineHeight": 1.25
    },
    {
      "id": "yKa4_w75Me0gYUXQa-ouZ",
      "type": "text",
      "x": 431.71129569459913,
      "y": 6961.2172266586385,
      "width": 511.179931640625,
      "height": 25,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "#ffc9c9",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [
        "O0VN_btwZJU4eMtOehD5b"
      ],
      "frameId": null,
      "index": "cATo",
      "roundness": null,
      "seed": 251320530,
      "version": 520,
      "versionNonce": 128490313,
      "isDeleted": false,
      "boundElements": [],
      "updated": 1775214283335,
      "link": null,
      "locked": false,
      "text": "x86处理器中利用lock前缀指令实现类似内存屏障的效果。",
      "fontSize": 20,
      "fontFamily": 6,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "x86处理器中利用lock前缀指令实现类似内存屏障的效果。",
      "autoResize": true,
      "lineHeight": 1.25
    },
    {
      "id": "bxKpIA-M5ayXzqW-ntC6j",
      "type": "rectangle",
      "x": 231.86088213566723,
      "y": 6957.88823640448,
      "width": 187,
      "height": 35,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "#b2f2bb",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [
        "O0VN_btwZJU4eMtOehD5b"
      ],
      "frameId": null,
      "index": "cATp",
      "roundness": {
        "type": 3
      },
      "seed": 1209613070,
      "version": 134,
      "versionNonce": 423123399,
      "isDeleted": false,
      "boundElements": [
