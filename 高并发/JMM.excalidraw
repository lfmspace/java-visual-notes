      "updated": 1775214283335,
      "link": null,
      "locked": false
    },
    {
      "id": "vTx6fw8ZvZxNMhcQxjAHO",
      "type": "text",
      "x": 452.1528698927739,
      "y": 6658.538385565569,
      "width": 261.8799743652344,
      "height": 25,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "#ffc9c9",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
