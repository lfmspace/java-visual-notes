      "isDeleted": false,
      "boundElements": [],
      "updated": 1775214283335,
      "link": null,
      "locked": false,
      "text": "1. 阻止屏障两边的指令重排序",
      "fontSize": 20,
      "fontFamily": 6,
      "textAlign": "center",
      "verticalAlign": "middle",
      "containerId": "hrTo-PpgMvFUvACeEoNVq",
      "originalText": "1. 阻止屏障两边的指令重排序",
      "autoResize": true,
      "lineHeight": 1.25
    },
    {
      "id": "IJ6npUDMjD1eQ9fY8gOZ1",
      "type": "rectangle",
      "x": 730.5949262545773,
      "y": 6653.538385565569,
      "width": 172,
      "height": 35,
      "angle": 0,
