      "text": "内存屏障有两个能力：",
      "fontSize": 20,
      "fontFamily": 6,
      "textAlign": "center",
      "verticalAlign": "middle",
      "containerId": "3v-y9YMhfklRi-1SQgs0k",
      "originalText": "内存屏障有两个能力：",
      "autoResize": true,
      "lineHeight": 1.25
    },
    {
