        "type": 3
      },
      "seed": 369935954,
      "version": 182,
      "versionNonce": 1172597065,
      "isDeleted": false,
      "boundElements": [
        {
          "id": "T7bToScHleFCN3gvBXSKn",
          "type": "text"
        }
      ],
      "updated": 1775214283335,
      "link": null,
      "locked": false
    },
    {
      "id": "T7bToScHleFCN3gvBXSKn",
      "type": "text",
      "x": 1522.453090856653,
      "y": 6565.50042996017,
      "width": 760.93994140625,
      "height": 25,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "#ffc9c9",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [
        "LyzgWa1LOI3ZV5YZTqM9t"
      ],
      "frameId": null,
      "index": "cAUL",
      "roundness": null,
      "seed": 1297524370,
      "version": 433,
      "versionNonce": 1206414279,
      "isDeleted": false,
      "boundElements": [],
      "updated": 1775214283335,
      "link": null,
      "locked": false,
      "text": "JMM遵循一个基本原则：只要不改变程序的执行结果，编译器和处理器怎么优化都行。",
      "fontSize": 20,
      "fontFamily": 6,
      "textAlign": "center",
      "verticalAlign": "middle",
      "containerId": "AbU1bLdM7u-eAV8IqxLYD",
      "originalText": "JMM遵循一个基本原则：只要不改变程序的执行结果，编译器和处理器怎么优化都行。",
      "autoResize": true,
      "lineHeight": 1.25
    },
    {
      "id": "MMnnmMVumIGG0TNgd2Jqk",
      "type": "text",
      "x": 1522.423061559778,
      "y": 6599.50042996017,
      "width": 491.6398620605469,
      "height": 25,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "#ffc9c9",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [
        "LyzgWa1LOI3ZV5YZTqM9t"
      ],
      "frameId": null,
      "index": "cAUM",
      "roundness": null,
      "seed": 1438270350,
      "version": 432,
      "versionNonce": 1509578793,
      "isDeleted": false,
      "boundElements": [],
      "updated": 1775214283335,
      "link": null,
      "locked": false,
      "text": "- as-if-serial语义保证单线程内程序的执行结果不被改变",
      "fontSize": 20,
      "fontFamily": 6,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "- as-if-serial语义保证单线程内程序的执行结果不被改变",
      "autoResize": true,
      "lineHeight": 1.25
    },
    {
      "id": "hd2ZM-bdWVZp3-M7ZBxgR",
      "type": "text",
      "x": 1522.423061559778,
      "y": 6633.50042996017,
      "width": 637.619873046875,
      "height": 25,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "#ffc9c9",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [
        "LyzgWa1LOI3ZV5YZTqM9t"
      ],
      "frameId": null,
      "index": "cAUN",
      "roundness": null,
      "seed": 749208658,
      "version": 432,
      "versionNonce": 462772967,
      "isDeleted": false,
      "boundElements": [],
      "updated": 1775214283335,
      "link": null,
      "locked": false,
      "text": "- happens-before关系保证正确同步的多线程程序的执行结果不被改变。",
      "fontSize": 20,
      "fontFamily": 6,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "- happens-before关系保证正确同步的多线程程序的执行结果不被改变。",
      "autoResize": true,
      "lineHeight": 1.25
    },
    {
      "id": "t5VNdTM8RcFR0Nq5roCRV",
      "type": "rectangle",
      "x": 1523.0757757576062,
      "y": 6659.757787674289,
      "width": 194,
      "height": 35,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "#ffec99",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [
        "LyzgWa1LOI3ZV5YZTqM9t"
      ],
      "frameId": null,
      "index": "cAUO",
      "roundness": {
        "type": 3
      },
      "seed": 1382426450,
      "version": 105,
      "versionNonce": 388983561,
      "isDeleted": false,
      "boundElements": [
        {
          "id": "yuDFBlR9nO6C2R4oPxRVV",
          "type": "text"
        }
      ],
      "updated": 1775214283335,
      "link": null,
      "locked": false
    },
    {
      "id": "yuDFBlR9nO6C2R4oPxRVV",
      "type": "text",
      "x": 1528.1458441169812,
      "y": 6664.757787674289,
      "width": 183.85986328125,
      "height": 25,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "#ffc9c9",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [
        "LyzgWa1LOI3ZV5YZTqM9t"
      ],
      "frameId": null,
      "index": "cAUP",
      "roundness": null,
      "seed": 1569171986,
      "version": 467,
      "versionNonce": 1175938567,
      "isDeleted": false,
      "boundElements": [],
      "updated": 1775214283335,
      "link": null,
      "locked": false,
      "text": "happens-before规则",
      "fontSize": 20,
      "fontFamily": 6,
      "textAlign": "center",
      "verticalAlign": "middle",
      "containerId": "t5VNdTM8RcFR0Nq5roCRV",
      "originalText": "happens-before规则",
      "autoResize": true,
      "lineHeight": 1.25
    },
    {
      "id": "SjtrgjYxEJVFnYuSbfZmU",
      "type": "text",
      "x": 1521.4809425268068,
      "y": 6697.815668641317,
      "width": 420.49981689453125,
      "height": 25,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "#ffc9c9",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [
        "LyzgWa1LOI3ZV5YZTqM9t"
      ],
      "frameId": null,
      "index": "cAUQ",
      "roundness": null,
      "seed": 1605187598,
      "version": 458,
      "versionNonce": 1442783721,
      "isDeleted": false,
      "boundElements": [],
      "updated": 1775214283335,
      "link": null,
      "locked": false,
      "text": "JSR-133规范定义了如下happens-before规则：",
      "fontSize": 20,
      "fontFamily": 6,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "JSR-133规范定义了如下happens-before规则：",
      "autoResize": true,
      "lineHeight": 1.25
    },
    {
      "id": "K7Dry8mU69aDSvKgJSYlA",
      "type": "text",
      "x": 1521.4809425268068,
      "y": 6735.06561984098,
      "width": 795.85986328125,
      "height": 25,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "#ffc9c9",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [
        "LyzgWa1LOI3ZV5YZTqM9t"
      ],
      "frameId": null,
      "index": "cAUR",
      "roundness": null,
      "seed": 653039570,
      "version": 458,
      "versionNonce": 1718291751,
      "isDeleted": false,
      "boundElements": [],
      "updated": 1775214283335,
      "link": null,
      "locked": false,
      "text": "1）程序顺序规则：一个线程中的每个操作，happens-before于该线程中的任意后续操作；",
      "fontSize": 20,
      "fontFamily": 6,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "1）程序顺序规则：一个线程中的每个操作，happens-before于该线程中的任意后续操作；",
      "autoResize": true,
      "lineHeight": 1.25
    },
    {
      "id": "JrxcHIiKw_Xh2y13Mm2a5",
      "type": "text",
      "x": 1521.4809425268068,
      "y": 6772.315571040643,
      "width": 655.85986328125,
      "height": 25,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "#ffc9c9",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [
        "LyzgWa1LOI3ZV5YZTqM9t"
      ],
      "frameId": null,
      "index": "cAUS",
      "roundness": null,
      "seed": 2108098126,
      "version": 459,
      "versionNonce": 1400175817,
      "isDeleted": false,
      "boundElements": [],
      "updated": 1775214283335,
      "link": null,
      "locked": false,
      "text": "2）锁定规则：对一个锁的解锁，happens-before于随后对这个锁的加锁；",
      "fontSize": 20,
      "fontFamily": 6,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "2）锁定规则：对一个锁的解锁，happens-before于随后对这个锁的加锁；",
      "autoResize": true,
      "lineHeight": 1.25
    },
    {
      "id": "CxKR9qt7v0lQHl5FUATb6",
      "type": "text",
      "x": 1521.4809425268068,
      "y": 6809.565522240306,
      "width": 978.2223482533035,
      "height": 25,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "#ffc9c9",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [
        "LyzgWa1LOI3ZV5YZTqM9t"
      ],
      "frameId": null,
      "index": "cAUT",
      "roundness": null,
      "seed": 1491979666,
      "version": 528,
      "versionNonce": 134008903,
      "isDeleted": false,
      "boundElements": [],
      "updated": 1775214283335,
      "link": null,
      "locked": false,
      "text": "3）volatile变量规则：对一个volatile变量的写操作，happens-before于任意后续对这个volatile变量的读操作；",
      "fontSize": 20,
      "fontFamily": 6,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "3）volatile变量规则：对一个volatile变量的写操作，happens-before于任意后续对这个volatile变量的读操作；",
      "autoResize": false,
      "lineHeight": 1.25
    },
    {
      "id": "ushutxu2koagk2Pv1GIeG",
      "type": "text",
      "x": 1521.4809425268068,
      "y": 6846.815473439969,
      "width": 938.3131929905483,
      "height": 25,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "#ffc9c9",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [
        "LyzgWa1LOI3ZV5YZTqM9t"
      ],
      "frameId": null,
      "index": "cAUU",
      "roundness": null,
      "seed": 1338838158,
      "version": 580,
      "versionNonce": 523008937,
      "isDeleted": false,
      "boundElements": [],
      "updated": 1775214283335,
      "link": null,
      "locked": false,
      "text": "4）传递规则：如果A happens-before B，并且B happens-before C，则A happens-before C；",
      "fontSize": 20,
      "fontFamily": 6,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "4）传递规则：如果A happens-before B，并且B happens-before C，则A happens-before C；",
      "autoResize": false,
      "lineHeight": 1.25
    },
    {
      "id": "jbInhm0gq-waVni0Lk7mD",
      "type": "text",
      "x": 1521.4809425268068,
      "y": 6884.065424639632,
      "width": 974.7286924373558,
      "height": 50,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "#ffc9c9",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [
        "LyzgWa1LOI3ZV5YZTqM9t"
      ],
      "frameId": null,
      "index": "cAUV",
      "roundness": null,
      "seed": 683821906,
      "version": 590,
      "versionNonce": 346632039,
      "isDeleted": false,
      "boundElements": [],
      "updated": 1775214283335,
      "link": null,
      "locked": false,
      "text": "5）线程启动规则：如果线程A调用线程B的start()方法来启动线程B，则start()操作happens-before于线程B中\n的任意操作；",
      "fontSize": 20,
      "fontFamily": 6,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "5）线程启动规则：如果线程A调用线程B的start()方法来启动线程B，则start()操作happens-before于线程B中的任意操作；",
      "autoResize": false,
      "lineHeight": 1.25
    },
    {
      "id": "49LNbSgKn0chJQ2-OmcKi",
      "type": "text",
      "x": 1521.4809425268068,
      "y": 6946.315375839295,
      "width": 978.8224074167098,
      "height": 25,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "#ffc9c9",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [
        "LyzgWa1LOI3ZV5YZTqM9t"
      ],
      "frameId": null,
      "index": "cAUW",
      "roundness": null,
      "seed": 1943554766,
      "version": 553,
      "versionNonce": 1230053001,
      "isDeleted": false,
      "boundElements": [],
      "updated": 1775214283335,
      "link": null,
      "locked": false,
      "text": "6）线程中断规则：对线程interrupt()方法的调用happens-before于被中断线程的代码检测到中断事件的发生；",
      "fontSize": 20,
      "fontFamily": 6,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "6）线程中断规则：对线程interrupt()方法的调用happens-before于被中断线程的代码检测到中断事件的发生；",
      "autoResize": false,
      "lineHeight": 1.25
    },
    {
      "id": "PkX-RBSBvTnFYq2uup_GS",
      "type": "text",
      "x": 1521.4809425268068,
      "y": 6977.565327038958,
      "width": 955.4562835288763,
      "height": 50,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "#ffc9c9",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [
        "LyzgWa1LOI3ZV5YZTqM9t"
      ],
      "frameId": null,
      "index": "cAUX",
      "roundness": null,
      "seed": 213979410,
      "version": 519,
      "versionNonce": 113027719,
      "isDeleted": false,
      "boundElements": [],
      "updated": 1775214283335,
      "link": null,
      "locked": false,
      "text": "7）线程终结规则：如果线程A执行操作ThreadB.join()并成功返回，那么线程B中的任意操作happens-before\n于线程A从ThreadB.join()操作成功返回；",
      "fontSize": 20,
      "fontFamily": 6,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "7）线程终结规则：如果线程A执行操作ThreadB.join()并成功返回，那么线程B中的任意操作happens-before于线程A从ThreadB.join()操作成功返回；",
      "autoResize": false,
      "lineHeight": 1.25
    },
    {
      "id": "_00fdHmJRzhY3rrhDWEk0",
      "type": "text",
      "x": 1521.4809425268068,
      "y": 7039.8152782386205,
      "width": 773.759765625,
      "height": 25,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "#ffc9c9",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [
        "LyzgWa1LOI3ZV5YZTqM9t"
      ],
      "frameId": null,
      "index": "cAUY",
      "roundness": null,
      "seed": 1751236878,
      "version": 499,
      "versionNonce": 1352557929,
      "isDeleted": false,
      "boundElements": [],
      "updated": 1775214283335,
      "link": null,
      "locked": false,
      "text": "8）对象终结规则：一个对象的初始化完成happens-before于它的finalize()方法的开始。",
      "fontSize": 20,
      "fontFamily": 6,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "8）对象终结规则：一个对象的初始化完成happens-before于它的finalize()方法的开始。",
      "autoResize": true,
      "lineHeight": 1.25
    },
