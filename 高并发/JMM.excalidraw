      "boundElements": [],
      "updated": 1775223494622,
      "link": null,
      "locked": false,
      "text": "由表中可以看出，volatile禁止重排序场景：",
      "fontSize": 20,
      "fontFamily": 6,
      "textAlign": "center",
      "verticalAlign": "middle",
      "containerId": "Y-l3G2vlALwjxQt3ZRa4N",
      "originalText": "由表中可以看出，volatile禁止重排序场景：",
      "autoResize": true,
      "lineHeight": 1.25
    },
    {
      "id": "mTInEqiFSj4fmYBl_2c1u",
      "type": "rectangle",
      "x": 1504.4524272896388,
      "y": 4623.919822726813,
      "width": 744,
      "height": 35,
