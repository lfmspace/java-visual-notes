    },
    {
      "id": "-e5StNglgJK-RYzMntCmc",
      "type": "text",
      "x": 2353.4245011849875,
      "y": 2972.531651359111,
      "width": 436.90579921091745,
      "height": 75,
      "angle": 0,
      "strokeColor": "#e03131",
      "backgroundColor": "#ffd8a8",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "cAUf",
      "roundness": null,
      "seed": 1534424425,
      "version": 183,
      "versionNonce": 938252073,
      "isDeleted": false,
      "boundElements": null,
      "updated": 1775216906960,
      "link": null,
      "locked": false,
      "text": "内存屏障是一种CPU或编译器的指令，\n用于禁止指令重排序并强制刷新/同步内存数据，\n从而保证多线程环境下的内存可见性和有序性。",
      "fontSize": 20,
      "fontFamily": 6,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "内存屏障是一种CPU或编译器的指令，\n用于禁止指令重排序并强制刷新/同步内存数据，\n从而保证多线程环境下的内存可见性和有序性。",
      "autoResize": false,
      "lineHeight": 1.25
    },
