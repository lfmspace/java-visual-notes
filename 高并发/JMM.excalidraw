        "fIJlpvfVVYrmhjuum5RMm",
        "VJuEekNtoTNqbL2VbtAhY",
        "4BmaygctqBaHX_eLRDTD0"
      ],
      "frameId": null,
      "index": "cAVC",
      "roundness": null,
      "seed": 756002322,
      "version": 300,
      "versionNonce": 2027981287,
      "isDeleted": false,
      "boundElements": [],
      "updated": 1775223494622,
      "link": null,
      "locked": false,
      "text": "1.  当第二个操作是volatile写时，不管第一个操作是什么，都不能重排序。【读后】",
      "fontSize": 20,
      "fontFamily": 6,
      "textAlign": "center",
      "verticalAlign": "middle",
      "containerId": "mTInEqiFSj4fmYBl_2c1u",
      "originalText": "1.  当第二个操作是volatile写时，不管第一个操作是什么，都不能重排序。【读后】",
      "autoResize": true,
      "lineHeight": 1.25
    },
    {
      "id": "Gk1ZgiJfR_bnmI1Xeza85",
