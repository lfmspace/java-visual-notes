      "isDeleted": false,
      "boundElements": [],
      "updated": 1775222525134,
      "link": null,
      "locked": false,
      "text": "synchronized关键字的作用是确保多个线程访问共享资源时的互斥性和可见性。",
      "fontSize": 20,
      "fontFamily": 6,
      "textAlign": "center",
      "verticalAlign": "middle",
      "containerId": "maYtOb-vN3Vcthm-NWAt2",
      "originalText": "synchronized关键字的作用是确保多个线程访问共享资源时的互斥性和可见性。",
      "autoResize": true,
      "lineHeight": 1.25
    },
    {
      "id": "d9sjzFp6QlExWQxQa7-o9",
      "type": "rectangle",
      "x": 1475.3450974784291,
      "y": 3717.183487003551,
      "width": 670,
      "height": 35,
