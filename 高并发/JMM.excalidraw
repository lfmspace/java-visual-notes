      ],
      "crop": {
        "x": 49.03810836967193,
        "y": 0,
        "width": 782.9618916303281,
        "height": 733,
        "naturalWidth": 832,
        "naturalHeight": 733
      }
    },
    {
      "id": "AbU1bLdM7u-eAV8IqxLYD",
      "type": "rectangle",
      "x": 1517.423061559778,
      "y": 6560.50042996017,
      "width": 771,
      "height": 35,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "#b2f2bb",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
