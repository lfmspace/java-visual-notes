          "type": "text"
        }
      ],
      "updated": 1775214283335,
      "link": null,
      "locked": false
    },
    {
      "id": "yDUYZ7wwKlczTTVlvnRGa",
      "type": "text",
      "x": 252.4763316384475,
      "y": 2979.1396562940868,
      "width": 608.239990234375,
      "height": 25,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "#ffc9c9",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [
        "ST7-q0ycvIHsOheW5TOgE"
      ],
      "frameId": null,
      "index": "cAPx",
