    },
    {
      "id": "EPrTYeYK5meG6_ZcKfmDB",
      "type": "text",
      "x": 238.24451922501635,
      "y": 5994.333358122962,
      "width": 1031.2449308900718,
      "height": 25,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "#ffc9c9",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [
        "RwKybnuJqLsM0mnDGcAC3",
        "O0VN_btwZJU4eMtOehD5b"
      ],
      "frameId": null,
      "index": "cAU2",
      "roundness": null,
      "seed": 426556494,
      "version": 335,
      "versionNonce": 1953421161,
      "isDeleted": false,
      "boundElements": [],
      "updated": 1775214283335,
      "link": null,
      "locked": false,
      "text": "上述内存屏障的插入策略非常保守，但它可以保证在任意处理器平台，任意程序中都能得到正确的volatile内存语义。",
      "fontSize": 20,
      "fontFamily": 6,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "上述内存屏障的插入策略非常保守，但它可以保证在任意处理器平台，任意程序中都能得到正确的volatile内存语义。",
      "autoResize": false,
      "lineHeight": 1.25
    },
    {
      "id": "pmlmMVuV50O2m5TomQTfD",
      "type": "image",
      "x": 238.24451922501635,
      "y": 6029.7411711408295,
      "width": 839.2186140646735,
      "height": 244.93323605574187,
      "angle": 0,
      "strokeColor": "transparent",
      "backgroundColor": "#ffc9c9",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [
        "RwKybnuJqLsM0mnDGcAC3",
        "O0VN_btwZJU4eMtOehD5b"
      ],
      "frameId": null,
      "index": "cAU3",
      "roundness": null,
      "seed": 248301266,
      "version": 394,
      "versionNonce": 1880846247,
      "isDeleted": false,
