      "isDeleted": false,
      "boundElements": [],
      "updated": 1775223494622,
      "link": null,
      "locked": false,
      "text": "当写一个volatile变量时，JMM会把该线程对应的本地内存中的共享变量值刷新到主内存。",
      "fontSize": 20,
      "fontFamily": 6,
      "textAlign": "left",
      "verticalAlign": "middle",
      "containerId": "RZ3GL5WLzdLLwdvstPXrF",
      "originalText": "当写一个volatile变量时，JMM会把该线程对应的本地内存中的共享变量值刷新到主内存。",
      "autoResize": true,
      "lineHeight": 1.25
    },
