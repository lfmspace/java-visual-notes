      "seed": 1561891278,
      "version": 839,
      "versionNonce": 2013423465,
      "isDeleted": false,
      "boundElements": [],
      "updated": 1775214283335,
      "link": null,
      "locked": false,
      "text": "根据JMM的规定，线程对共享变量的所有操作都必须在自己的本地内存中进行，不能直接从主内存中读取。",
      "fontSize": 20,
      "fontFamily": 6,
      "textAlign": "center",
      "verticalAlign": "middle",
      "containerId": "15KTVV5SOT2y2m2j7JJTl",
      "originalText": "根据JMM的规定，线程对共享变量的所有操作都必须在自己的本地内存中进行，不能直接从主内存中读取。",
      "autoResize": true,
      "lineHeight": 1.25
    },
    {
      "id": "6JRpqybxuclWOOJg2-m_u",
      "type": "rectangle",
      "x": 247.096326755635,
      "y": 2974.1396562940868,
      "width": 619,
      "height": 35,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "#b2f2bb",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [
        "ST7-q0ycvIHsOheW5TOgE"
      ],
      "frameId": null,
      "index": "cAPw",
      "roundness": {
        "type": 3
      },
