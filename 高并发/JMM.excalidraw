      "seed": 48750866,
      "version": 479,
      "versionNonce": 2002024135,
      "isDeleted": false,
      "boundElements": [],
      "updated": 1775214283335,
      "link": null,
      "locked": false,
      "text": "主内存与工作内存交互协议",
      "fontSize": 20,
      "fontFamily": 6,
      "textAlign": "center",
      "verticalAlign": "middle",
      "containerId": "E9Pd5OKGl95nmOVd3aTYH",
      "originalText": "主内存与工作内存交互协议",
      "autoResize": true,
      "lineHeight": 1.25
    },
    {
      "id": "ep7KVrk5wAFe1NaySJczk",
      "type": "rectangle",
      "x": 184.55423852948866,
      "y": 3336.6773927191152,
      "width": 795,
      "height": 35,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "#fff9db",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [
        "nYLKgYJy9UDrlwaFLKmbB",
        "DYS8MxdyrXhAaGIRkgDrN"
      ],
      "frameId": null,
      "index": "cAR0",
      "roundness": {
        "type": 3
      },
      "seed": 708579534,
      "version": 43,
      "versionNonce": 795376937,
      "isDeleted": false,
      "boundElements": [
        {
          "id": "zWQN8VDLUlhCpnY4VDDH9",
          "type": "text"
        }
      ],
      "updated": 1775214283335,
      "link": null,
      "locked": false
    },
    {
      "id": "zWQN8VDLUlhCpnY4VDDH9",
      "type": "text",
      "x": 189.55423852948866,
      "y": 3341.6773927191152,
      "width": 777.9999389648438,
      "height": 25,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "#ffc9c9",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [
        "nYLKgYJy9UDrlwaFLKmbB",
        "DYS8MxdyrXhAaGIRkgDrN"
      ],
      "frameId": null,
      "index": "cAR1",
      "roundness": null,
      "seed": 1758458126,
      "version": 527,
      "versionNonce": 927466983,
      "isDeleted": false,
      "boundElements": [],
      "updated": 1775214283335,
      "link": null,
      "locked": false,
      "text": "主内存与工作内存之间的具体交互协议，Java内存模型定义了以下八种原子操作来完成：",
      "fontSize": 20,
      "fontFamily": 6,
      "textAlign": "left",
      "verticalAlign": "middle",
      "containerId": "ep7KVrk5wAFe1NaySJczk",
      "originalText": "主内存与工作内存之间的具体交互协议，Java内存模型定义了以下八种原子操作来完成：",
