    {
      "id": "3YcexF4OAVSVIRh81Esam",
      "type": "text",
      "x": 253.35228592889337,
      "y": 2910.817339689887,
      "width": 940.93994140625,
      "height": 25,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "#ffc9c9",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [
        "ST7-q0ycvIHsOheW5TOgE"
      ],
