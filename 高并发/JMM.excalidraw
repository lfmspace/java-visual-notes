      "lineHeight": 1.25
    },
    {
      "id": "FR9O6prwNqU6LU7YA4YFX",
      "type": "text",
      "x": 230.87065362445605,
      "y": 6455.141362867935,
      "width": 397.0999755859375,
      "height": 25,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "#ffc9c9",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [
        "O0VN_btwZJU4eMtOehD5b"
      ],
      "frameId": null,
      "index": "cATd",
      "roundness": null,
      "seed": 173439502,
      "version": 296,
      "versionNonce": 431262471,
      "isDeleted": false,
      "boundElements": [],
      "updated": 1775214283335,
      "link": null,
      "locked": false,
      "text": "拿X86处理器来说，有几种主要的内存屏障：",
      "fontSize": 20,
      "fontFamily": 6,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "拿X86处理器来说，有几种主要的内存屏障：",
      "autoResize": true,
      "lineHeight": 1.25
    },
    {
      "id": "9uLcb7ag6BUX2rOrKLePg",
      "type": "text",
      "x": 230.87065362445605,
      "y": 6489.855572112923,
      "width": 332.6197509765625,
      "height": 25,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "#ffc9c9",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [
        "O0VN_btwZJU4eMtOehD5b"
      ],
      "frameId": null,
      "index": "cATe",
      "roundness": null,
      "seed": 1206941138,
      "version": 296,
      "versionNonce": 1911737577,
      "isDeleted": false,
      "boundElements": [],
      "updated": 1775214283335,
      "link": null,
      "locked": false,
      "text": "1. lfence，是一种Load Barrier 读屏障",
      "fontSize": 20,
      "fontFamily": 6,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "1. lfence，是一种Load Barrier 读屏障",
      "autoResize": true,
      "lineHeight": 1.25
    },
    {
      "id": "5f7gbCazr03IdhIFP-aTv",
      "type": "text",
      "x": 230.87065362445605,
      "y": 6524.569781357912,
      "width": 330.23974609375,
      "height": 25,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "#ffc9c9",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [
        "O0VN_btwZJU4eMtOehD5b"
      ],
      "frameId": null,
      "index": "cATf",
      "roundness": null,
      "seed": 1171785806,
      "version": 296,
      "versionNonce": 1964741159,
      "isDeleted": false,
      "boundElements": [],
      "updated": 1775214283335,
      "link": null,
      "locked": false,
      "text": "2. sfence, 是一种Store Barrier 写屏障",
      "fontSize": 20,
      "fontFamily": 6,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "2. sfence, 是一种Store Barrier 写屏障",
      "autoResize": true,
      "lineHeight": 1.25
    },
    {
