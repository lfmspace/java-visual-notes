    {
      "id": "MP_ePWNSKqUHHlfmpwuv8",
      "type": "rectangle",
      "x": 2446.5671100617683,
      "y": 3387.1897704725197,
      "width": 798,
      "height": 135,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "#eebefa",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [
        "9AMUZ0GWPTsnLgP_3Cwlq"
      ],
      "frameId": null,
      "index": "cAUc",
