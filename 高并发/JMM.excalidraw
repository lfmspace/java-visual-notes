      "link": null,
      "locked": false,
      "text": "锁获取和释放的内存语义：",
      "fontSize": 20,
      "fontFamily": 6,
      "textAlign": "center",
      "verticalAlign": "middle",
      "containerId": "5YpR1ZiDxoD0vEmK9SE4l",
      "originalText": "锁获取和释放的内存语义：",
      "autoResize": true,
      "lineHeight": 1.25
    },
    {
      "id": "maYtOb-vN3Vcthm-NWAt2",
      "type": "rectangle",
      "x": 1475.3450974784291,
