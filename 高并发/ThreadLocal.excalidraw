    {
      "id": "g413EeGRIujiAxo1NFtSK",
      "type": "text",
      "x": 1323.9791733287252,
      "y": -5408.068577112445,
      "width": 782.4597778320312,
      "height": 75,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "#e3fafc",
      "fillStyle": "solid",
      "strokeWidth": 1,
      "strokeStyle": "dotted",
      "roughness": 0,
      "opacity": 100,
      "groupIds": [
        "nxAXnUCeG4LFTfvnKtl6B",
        "E2OjFDSsfvyvUlSZewAe2",
        "X_B2WVO9EzUiMBjL9oyUu"
