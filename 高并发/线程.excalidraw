      "isDeleted": false,
      "boundElements": [],
      "updated": 1772800634760,
      "link": null,
      "locked": false,
      "text": "// 构造方法的参数是给线程指定名字，推荐\nThread t1 = new Thread(\"t1\") {\n     @Override\n     // run 方法内实现了要执行的任务\n     public void run() {\n         log.debug(\"Hello Thread\");\n     }\n};\nt1.start();",
      "fontSize": 20,
      "fontFamily": 6,
      "textAlign": "left",
      "verticalAlign": "middle",
      "containerId": "gEcPikrfgdj1dA9Fys2n8",
      "originalText": "// 构造方法的参数是给线程指定名字，推荐\nThread t1 = new Thread(\"t1\") {\n     @Override\n     // run 方法内实现了要执行的任务\n     public void run() {\n         log.debug(\"Hello Thread\");\n     }\n};\nt1.start();",
      "autoResize": true,
      "lineHeight": 1.25
    },
