    {
      "id": "w1z3ZwtIkO3lB6eoqEMCE",
      "type": "text",
      "x": 1693.6473028225205,
      "y": 7410.55549963386,
      "width": 798.179931640625,
      "height": 75,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "#e3fafc",
      "fillStyle": "solid",
      "strokeWidth": 1,
      "strokeStyle": "dotted",
      "roughness": 0,
      "opacity": 100,
      "groupIds": [
        "Rb1NSGG46xwqatFYjYkRG",
        "K2ec4Op-84scIdUQVxKCB",
        "YaKXDVml4vPQfRsrCukPc",
