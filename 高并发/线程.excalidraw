    {
      "id": "RsQmAqZv-1CPChjE70fYf",
      "type": "text",
      "x": -583.1934075623968,
      "y": 5621.181433948196,
      "width": 462.6396484375,
      "height": 500,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "#e3fafc",
