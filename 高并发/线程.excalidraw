    {
      "id": "qiB6n6E9579k2o8SSkEkX",
      "type": "text",
      "x": -991.5139343067449,
      "y": 1589.4964882993079,
      "width": 640.93994140625,
      "height": 50,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "#b6e683",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
