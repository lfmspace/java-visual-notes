    {
      "id": "KZYlIxfbYrUZW2I5_UDz9",
      "type": "text",
      "x": 1700.595170222712,
      "y": 6018.964095903704,
      "width": 781.35986328125,
      "height": 50,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "#e3fafc",
      "fillStyle": "solid",
      "strokeWidth": 1,
      "strokeStyle": "dotted",
      "roughness": 0,
      "opacity": 100,
      "groupIds": [
        "82JVMefzfTrzLnJA-S7V0",
        "ZE_wJGF9UYF80ppslyzWv",
        "YaKXDVml4vPQfRsrCukPc",
        "bWVdQa7sFAJdQhrqlmPzd"
      ],
      "frameId": null,
      "index": "cD2j",
      "roundness": null,
      "seed": 1907659259,
      "version": 855,
      "versionNonce": 950911856,
      "isDeleted": true,
      "boundElements": [],
      "updated": 1772800634761,
      "link": null,
      "locked": false,
      "text": "这也是LongAdder设计的精妙之处：尽量减少热点冲突，不到最后万不得已，尽量将CAS\n操作延迟。",
      "fontSize": 20,
      "fontFamily": 6,
      "textAlign": "left",
      "verticalAlign": "middle",
      "containerId": "tS_DB7QXLwvrNLpw7zk-u",
      "originalText": "这也是LongAdder设计的精妙之处：尽量减少热点冲突，不到最后万不得已，尽量将CAS操作延迟。",
      "autoResize": true,
      "lineHeight": 1.25
    },
