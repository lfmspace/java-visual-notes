    },
    {
      "id": "8LAYmzWAIMweO3rwRKVnK",
      "type": "text",
      "x": -1805.7063756199057,
      "y": 9101.778127065918,
      "width": 180,
      "height": 25,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "#e3fafc",
      "fillStyle": "solid",
      "strokeWidth": 1,
      "strokeStyle": "dotted",
      "roughness": 0,
