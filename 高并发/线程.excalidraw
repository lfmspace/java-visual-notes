      "boundElements": [],
      "updated": 1772806938079,
      "link": null,
      "locked": false,
      "text": "Java线程之间的通信由JMM控制，JMM决定一个线程对共享变量的写入何\n时对另一个线程可见。",
      "fontSize": 20,
      "fontFamily": 6,
      "textAlign": "left",
      "verticalAlign": "middle",
      "containerId": "j3hdDQzIRL_cKDwGDnBNL",
      "originalText": "Java线程之间的通信由JMM控制，JMM决定一个线程对共享变量的写入何时对另一个线程可见。",
      "autoResize": true,
      "lineHeight": 1.25
    },
    {
      "id": "zZmNjhtXpztxRGOO5ToLx",
      "type": "rectangle",
      "x": -996.5139343067449,
      "y": 1584.4964882993079,
      "width": 657.25,
      "height": 60,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "#ffec99",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 0,
      "opacity": 100,
      "groupIds": [
        "F2fyhwN_KT7tmlqjYPHht",
        "3E99sJEpDS9guMTW4-_HH",
        "PJgacFv8shtWpVVMoDjKV",
        "5St6DHBrilcnkS4xLVo25"
      ],
