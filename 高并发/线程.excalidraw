    },
    {
      "id": "KvFP_8dGI18h1sr0xjbkz",
      "type": "text",
      "x": -1309.0633569111926,
      "y": 4585.348876851896,
      "width": 680,
      "height": 100,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "#ffffff",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 0,
