    {
      "id": "OeKHfR5PV6tr4VvvKxs-d",
      "type": "text",
      "x": -803.110679122581,
      "y": 4270.527285420131,
      "width": 720.63916015625,
      "height": 125,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "#f8f9fa",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 0,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "cCWt",
      "roundness": null,
      "seed": 40991221,
      "version": 296,
      "versionNonce": 724295024,
      "isDeleted": true,
      "boundElements": [],
      "updated": 1772800634760,
      "link": null,
      "locked": false,
      "text": "CompletableFuture<Integer> future = CompletableFuture.supplyAsync(() -> 10)\n    .thenCompose(value -> CompletableFuture.supplyAsync(() -> value * 2))\n    .thenCompose(value -> CompletableFuture.supplyAsync(() -> value + 5));\n// 输出: 25\nfuture.thenAccept(System.out::println);",
      "fontSize": 20,
      "fontFamily": 6,
      "textAlign": "left",
      "verticalAlign": "middle",
      "containerId": "uKr96VxTzyRffyGjHqRq2",
      "originalText": "CompletableFuture<Integer> future = CompletableFuture.supplyAsync(() -> 10)\n    .thenCompose(value -> CompletableFuture.supplyAsync(() -> value * 2))\n    .thenCompose(value -> CompletableFuture.supplyAsync(() -> value + 5));\n// 输出: 25\nfuture.thenAccept(System.out::println);",
      "autoResize": true,
      "lineHeight": 1.25
    },
    {
      "id": "iwG3OY9kDm-6ge6JFw7Fn",
      "type": "text",
      "x": -805.6503665063232,
