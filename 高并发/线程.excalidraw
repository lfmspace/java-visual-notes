      "index": "cCpX",
      "roundness": null,
      "seed": 573496757,
      "version": 4,
      "versionNonce": 2043134320,
      "isDeleted": true,
      "boundElements": [],
      "updated": 1772800634761,
      "link": null,
      "locked": false,
      "text": "AtomicLong是利用了底层的CAS操作来提供并发性的，比如addAndGet方法：",
      "fontSize": 20,
      "fontFamily": 6,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "AtomicLong是利用了底层的CAS操作来提供并发性的，比如addAndGet方法：",
      "autoResize": true,
      "lineHeight": 1.25
    },
    {
