      "textAlign": "center",
      "verticalAlign": "middle",
      "containerId": "euYZtr-Rhv7qxP6JU4XWV",
      "originalText": "java中CAS失败后的自旋由AutomicInteger实现",
      "autoResize": true,
      "lineHeight": 1.25
    },
    {
      "id": "AjnoMphOKBoDp3QpYcaGg",
      "type": "text",
      "x": -1862.7766269702208,
      "y": 8018.238003136079,
      "width": 202.7599639892578,
      "height": 25,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "#e3fafc",
