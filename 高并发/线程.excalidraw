      "boundElements": [],
      "updated": 1772800634760,
      "link": null,
      "locked": false,
      "text": "ThreadLocal用于在同一线程内共享数据库连接对象，避免线程池复\n用时连接泄漏或错误",
      "fontSize": 20,
      "fontFamily": 6,
      "textAlign": "center",
      "verticalAlign": "middle",
      "containerId": "hClG_H-NuuSca9Q0oOhmS",
      "originalText": "ThreadLocal用于在同一线程内共享数据库连接对象，避免线程池复用时连接泄漏或错误",
      "autoResize": true,
      "lineHeight": 1.25
    },
