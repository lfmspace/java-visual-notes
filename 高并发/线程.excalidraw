      "link": null,
      "locked": false,
      "text": "高并发时，除非全局加锁，否则得不到程序运行中某个时刻绝对准确的值",
      "fontSize": 20,
      "fontFamily": 6,
      "textAlign": "center",
      "verticalAlign": "middle",
      "containerId": "IUcA4odJXJlaq94iJ-nEP",
      "originalText": "高并发时，除非全局加锁，否则得不到程序运行中某个时刻绝对准确的值",
      "autoResize": true,
      "lineHeight": 1.25
    },
