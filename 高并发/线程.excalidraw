    {
      "id": "DtH9bed4Aw-dt1m2JX0Jc",
      "type": "text",
      "x": -316.9601738606556,
      "y": 4766.469286909849,
      "width": 1628.4395751953125,
      "height": 125,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "#ffc9c9",
      "fillStyle": "solid",
      "strokeWidth": 2,
