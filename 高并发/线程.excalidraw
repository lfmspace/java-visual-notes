      "isDeleted": true,
      "boundElements": [],
      "updated": 1772800634760,
      "link": null,
      "locked": false,
      "text": "1）获得对象的锁。",
      "fontSize": 20,
      "fontFamily": 6,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "1）获得对象的锁。",
      "autoResize": true,
      "lineHeight": 1.25
    },
    {
      "id": "_6PRFLVB_gVGaLV--D-VT",
      "type": "text",
      "x": -1273.9204650231372,
      "y": 7979.315636490111,
      "width": 132,
      "height": 25,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "#ffffff",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 0,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
