    {
      "id": "OjacEnzQoJJfLYMGe4Uyq",
      "type": "text",
      "x": -686.6051542357206,
      "y": 6839.93890444539,
      "width": 681.5797729492188,
      "height": 125,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "#d0bfff",
      "fillStyle": "solid",
      "strokeWidth": 1,
      "strokeStyle": "solid",
      "roughness": 0,
      "opacity": 100,
      "groupIds": [],
