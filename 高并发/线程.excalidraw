      "text": "‌任务链式依赖",
      "fontSize": 20,
      "fontFamily": 6,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "‌任务链式依赖",
      "autoResize": true,
