      "text": "Future实际采用FutureTask实现，该对象相当于是消费者和生产者的桥梁",
      "fontSize": 20,
      "fontFamily": 6,
      "textAlign": "center",
      "verticalAlign": "middle",
      "containerId": "3MFlbtLBoWst0i-ihzcfC",
      "originalText": "Future实际采用FutureTask实现，该对象相当于是消费者和生产者的桥梁",
      "autoResize": true,
      "lineHeight": 1.25
    },
    {
      "id": "Xy7PllewKjkdKfTGLrnHx",
      "type": "rectangle",
      "x": -6157.979714857327,
      "y": 2306.3094548362446,
      "width": 971.4165649414058,
      "height": 310,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "#f8f9fa",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 0,
      "opacity": 100,
      "groupIds": [
        "9tgodOgENx7Jht8tujCsl",
        "PAVVmsQ3CL74LapuKQKbh",
        "Ck7smgeqvEVFuTCo53UeW"
      ],
      "frameId": "6UhhB8zWpRnyjFzvSf06g",
      "index": "cCcc",
      "roundness": null,
      "seed": 1996081051,
