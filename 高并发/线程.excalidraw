      "fontFamily": 6,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "AtomicReference作用是对普通对象的封装，它可以保证你在修改对象引用时的线程安全性。",
      "autoResize": false,
      "lineHeight": 1.25
    },
