    {
      "id": "WCwnNNxPohgzA5UR33C7b",
      "type": "text",
      "x": -2281.8209950017463,
      "y": 14618.574584551823,
      "width": 693.6397705078125,
      "height": 25,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "#e3fafc",
      "fillStyle": "solid",
      "strokeWidth": 1,
      "strokeStyle": "dotted",
      "roughness": 0,
      "opacity": 100,
      "groupIds": [],
