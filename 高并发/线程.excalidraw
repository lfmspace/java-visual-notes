      "updated": 1772800634760,
      "link": null,
      "locked": false,
      "text": "// 创建任务对象\nRunnable task2 = new Runnable() {\n     @Override\n     public void run() {\n         log.debug(\"hello\");\n     }\n};\n// 参数1 是任务对象; 参数2 是线程名字，推荐\nThread t2 = new Thread(task2, \"t2\");\nt2.start();",
      "fontSize": 20,
      "fontFamily": 6,
      "textAlign": "left",
      "verticalAlign": "middle",
      "containerId": "bPLkRLHCruTRSshTOlMJi",
      "originalText": "// 创建任务对象\nRunnable task2 = new Runnable() {\n     @Override\n     public void run() {\n         log.debug(\"hello\");\n     }\n};\n// 参数1 是任务对象; 参数2 是线程名字，推荐\nThread t2 = new Thread(task2, \"t2\");\nt2.start();",
      "autoResize": true,
      "lineHeight": 1.25
    },
