      "isDeleted": true,
      "boundElements": [],
      "updated": 1772800634760,
      "link": null,
      "locked": false,
      "text": "Java中的管道输入/输出流主要包括了如下4种具体实现：、、\n和，前两种，而后两种",
      "fontSize": 20,
      "fontFamily": 6,
      "textAlign": "center",
      "verticalAlign": "middle",
      "containerId": "vXFF3bUTriYs5CwUnR78v",
      "originalText": "Java中的管道输入/输出流主要包括了如下4种具体实现：、、和，前两种，而后两种",
      "autoResize": true,
      "lineHeight": 1.25
    },
    {
      "id": "7hVj8rafi2nxM1Gt6tn4b",
      "type": "text",
      "x": -1322.3263584025442,
      "y": 6744.438911455118,
      "width": 125.79998779296875,
      "height": 25,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "#ffffff",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 0,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "cCQC",
      "roundness": null,
      "seed": 1119182619,
      "version": 35,
