    {
      "id": "b131HvOR6g9toWgt41Cbv",
      "type": "text",
      "x": -50.65022118452259,
      "y": 4280.2893209716585,
      "width": 761.8591918945312,
      "height": 200,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "#f8f9fa",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 0,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "cCWr",
      "roundness": null,
      "seed": 2064778677,
      "version": 338,
      "versionNonce": 1127664496,
      "isDeleted": true,
      "boundElements": [],
      "updated": 1772800634760,
      "link": null,
      "locked": false,
      "text": "// 使用 thenCompose（推荐）\nCompletableFuture<String> result = CompletableFuture.supplyAsync(() -> \"Hello\")\n    .thenCompose(s -> CompletableFuture.supplyAsync(() -> s + \" World\"));\n\n// 对比使用 thenApply（易嵌套）\nCompletableFuture<String> result2 = CompletableFuture.supplyAsync(() -> \"Hello\")\n    .thenApply(s -> CompletableFuture.supplyAsync(() -> s + \" World\"))\n    .thenApply(future -> future.join()); // 需要手动 join",
      "fontSize": 20,
      "fontFamily": 6,
      "textAlign": "left",
      "verticalAlign": "middle",
      "containerId": "in7s2vzdHxHUL_30hmVHb",
      "originalText": "// 使用 thenCompose（推荐）\nCompletableFuture<String> result = CompletableFuture.supplyAsync(() -> \"Hello\")\n    .thenCompose(s -> CompletableFuture.supplyAsync(() -> s + \" World\"));\n\n// 对比使用 thenApply（易嵌套）\nCompletableFuture<String> result2 = CompletableFuture.supplyAsync(() -> \"Hello\")\n    .thenApply(s -> CompletableFuture.supplyAsync(() -> s + \" World\"))\n    .thenApply(future -> future.join()); // 需要手动 join",
      "autoResize": true,
      "lineHeight": 1.25
    },
    {
      "id": "uKr96VxTzyRffyGjHqRq2",
