      "fillStyle": "solid",
      "strokeWidth": 1,
      "strokeStyle": "dotted",
      "roughness": 0,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "cCpY",
      "roundness": null,
      "seed": 2098977589,
      "version": 6,
      "versionNonce": 950226320,
      "isDeleted": true,
