      "link": null,
      "locked": false
    },
    {
      "id": "mrVCfTaUbunXNUAQUx4YN",
      "type": "text",
      "x": 1700.595170222712,
      "y": 5928.024091358584,
      "width": 782.4597778320312,
      "height": 75,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "#e3fafc",
      "fillStyle": "solid",
      "strokeWidth": 1,
      "strokeStyle": "dotted",
      "roughness": 0,
      "opacity": 100,
      "groupIds": [
        "82JVMefzfTrzLnJA-S7V0",
        "ZE_wJGF9UYF80ppslyzWv",
        "YaKXDVml4vPQfRsrCukPc",
        "bWVdQa7sFAJdQhrqlmPzd"
      ],
      "frameId": null,
      "index": "cD2h",
      "roundness": null,
      "seed": 1712866491,
      "version": 867,
      "versionNonce": 612200816,
      "isDeleted": true,
      "boundElements": [],
      "updated": 1772800634761,
      "link": null,
      "locked": false,
      "text": "如果Cell[]数组未初始化，会调用父类的longAccumelate去初始化Cell[]，如果Cell[]已经\n初始化但是冲突发生在Cell单元内，则也调用父类的longAccumelate，此时可能就需要对\nCell[]扩容了。",
      "fontSize": 20,
      "fontFamily": 6,
      "textAlign": "left",
      "verticalAlign": "middle",
      "containerId": "e4x4r8Hwve1p3cnC4VTQU",
      "originalText": "如果Cell[]数组未初始化，会调用父类的longAccumelate去初始化Cell[]，如果Cell[]已经初始化但是冲突发生在Cell单元内，则也调用父类的longAccumelate，此时可能就需要对Cell[]扩容了。",
      "autoResize": true,
      "lineHeight": 1.25
    },
