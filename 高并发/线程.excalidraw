      "link": null,
      "locked": false,
      "text": "Java内存模型（Java Memory Model，简称JMM）",
      "fontSize": 20,
      "fontFamily": 6,
      "textAlign": "center",
      "verticalAlign": "middle",
      "containerId": "MPYexpRCw5m4ptIzDfzvg",
      "originalText": "Java内存模型（Java Memory Model，简称JMM）",
      "autoResize": true,
      "lineHeight": 1.25
    },
    {
      "id": "kyPtBqVSITSAb2nOEbCum",
      "type": "rectangle",
      "x": -996.5139343067449,
      "y": 1648.7168796216754,
      "width": 659.2084350585938,
      "height": 60,
      "angle": 0,
      "strokeColor": "#1e1e1e",
