      "text": "通知方遵循如下原则。",
      "fontSize": 20,
      "fontFamily": 6,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "通知方遵循如下原则。",
      "autoResize": true,
      "lineHeight": 1.25
    },
    {
      "id": "aYTPXLtjtfyfZbFoD7wDz",
      "type": "text",
      "x": -1289.9204650231372,
      "y": 7949.315636490111,
      "width": 172,
      "height": 25,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "#ffffff",
      "fillStyle": "solid",
