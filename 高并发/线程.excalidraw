      "text": "AtomicIntegerFieldUpdater可以线程安全地更新对象中的整型变量。",
      "fontSize": 20,
      "fontFamily": 6,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "AtomicIntegerFieldUpdater可以线程安全地更新对象中的整型变量。",
      "autoResize": true,
      "lineHeight": 1.25
    },
    {
      "id": "YALuJ3Rb01yIaIqalGwRx",
      "type": "image",
      "x": -1948.002250810151,
      "y": 13658.481725310128,
      "width": 442.1133525456292,
      "height": 581.1111111111111,
      "angle": 0,
      "strokeColor": "transparent",
      "backgroundColor": "#e3fafc",
      "fillStyle": "solid",
      "strokeWidth": 1,
      "strokeStyle": "dotted",
      "roughness": 0,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "cCpU",
      "roundness": null,
      "seed": 506241179,
      "version": 37,
      "versionNonce": 1451651472,
      "isDeleted": true,
      "boundElements": [],
      "updated": 1772800634761,
      "link": null,
      "locked": false,
      "status": "saved",
      "fileId": "63438dc21eb2a6ad70034b360418d90bd3284ebd",
