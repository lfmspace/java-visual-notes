    {
      "id": "fS81ShxARcNOXwxW9f0km",
      "type": "text",
      "x": 117.72277967475543,
      "y": 6943.693264056806,
      "width": 927.3197631835938,
      "height": 250,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "#e7f5ff",
      "fillStyle": "solid",
      "strokeWidth": 1,
      "strokeStyle": "dashed",
      "roughness": 0,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "cCep",
      "roundness": null,
      "seed": 2045431547,
      "version": 518,
      "versionNonce": 344844656,
      "isDeleted": true,
      "boundElements": [],
      "updated": 1772800634760,
      "link": null,
      "locked": false,
      "text": "//AtomicInteger是一个提供原子操作的Integer类，通过线程安全的方式操作加减,适合高并发情况下的使用\nprivate static AtomicInteger nextHashCode =  new AtomicInteger();\n //特殊的hash值\nprivate static final int HASH_INCREMENT = 0x61c88647;\n\nprivate static int nextHashCode() {\n    return nextHashCode.getAndAdd(HASH_INCREMENT);\n}\n\nprivate final int threadLocalHashCode = nextHashCode();",
      "fontSize": 20,
      "fontFamily": 6,
      "textAlign": "left",
      "verticalAlign": "middle",
      "containerId": "MCpZvXAYTtDjOJmA8pl40",
      "originalText": "//AtomicInteger是一个提供原子操作的Integer类，通过线程安全的方式操作加减,适合高并发情况下的使用\nprivate static AtomicInteger nextHashCode =  new AtomicInteger();\n //特殊的hash值\nprivate static final int HASH_INCREMENT = 0x61c88647;\n\nprivate static int nextHashCode() {\n    return nextHashCode.getAndAdd(HASH_INCREMENT);\n}\n\nprivate final int threadLocalHashCode = nextHashCode();",
      "autoResize": true,
      "lineHeight": 1.25
    },
    {
      "id": "4jcy2I1jZNgWWJ2HtvH65",
      "type": "rectangle",
      "x": -691.6051542357206,
