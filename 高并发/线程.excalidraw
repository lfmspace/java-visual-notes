    {
      "id": "s_y7FFicp-LjrgLtGNGYK",
      "type": "text",
      "x": -1896.434459357215,
      "y": 22058.574418533004,
      "width": 376.199951171875,
      "height": 25,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "#e3fafc",
