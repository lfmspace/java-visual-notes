      "text": "方式1：使用 Thread类或继承Thread类",
      "fontSize": 20,
      "fontFamily": 6,
      "textAlign": "center",
      "verticalAlign": "middle",
      "containerId": "cWX3PwOq39OlTGIPYb2Bh",
      "originalText": "方式1：使用 Thread类或继承Thread类",
