      "isDeleted": false,
      "boundElements": [],
      "updated": 1767944057738,
      "link": null,
      "locked": false,
      "text": "如果 key 对应的值是 value，则移除 K-V，返回 true。否则不移除，返回 false。",
      "fontSize": 20,
      "fontFamily": 6,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "如果 key 对应的值是 value，则移除 K-V，返回 true。否则不移除，返回 false。",
      "autoResize": true,
      "lineHeight": 1.25
    },
    {
