    {
      "id": "Y916RylBdY4cS65K__O0V",
      "type": "text",
      "x": -1140.3104243642972,
      "y": 3839.4992443178608,
      "width": 40,
      "height": 25,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [
        "ENuQovnC3AhFUQY346EBK",
        "CO7n1OkvP64npOCvScbsr",
        "2j6AWX3xj9qij90x5ynAu"
      ],
      "frameId": null,
      "index": "c9YSb",
