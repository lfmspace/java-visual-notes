      "text": "JDK1.8中的ConcurrentHashMap",
      "fontSize": 20,
      "fontFamily": 6,
      "textAlign": "center",
      "verticalAlign": "middle",
      "containerId": "Ism2ZDScLghkvKfxKpGd8",
