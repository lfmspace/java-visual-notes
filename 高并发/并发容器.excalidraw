      "width": 125,
      "height": 35,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "#b2f2bb",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 0,
      "opacity": 100,
      "groupIds": [
        "KvEh5edbYabu0Q0VY8dAC",
        "2j6AWX3xj9qij90x5ynAu"
      ],
      "frameId": null,
      "index": "c9YUV",
      "roundness": {
        "type": 3
      },
      "seed": 1033830865,
      "version": 288,
      "versionNonce": 119853464,
