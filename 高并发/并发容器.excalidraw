      "link": null,
      "locked": false
    },
    {
      "id": "Jsg76rKfqY2vk5mc6u72Z",
      "type": "text",
      "x": -439.04999143518694,
      "y": 4498.331238307901,
      "width": 40,
      "height": 25,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
