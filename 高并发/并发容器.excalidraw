      "locked": false
    },
    {
      "id": "Iqb-xdokIq6F1KRk7uPTm",
      "type": "text",
      "x": -306.3060033406257,
      "y": 4882.230979132958,
      "width": 114.09989929199219,
      "height": 25,
      "angle": 0,
      "strokeColor": "#1e1e1e",
