      "text": "- 链表的节点数量大于等于树化阈值8",
      "fontSize": 20,
      "fontFamily": 6,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "- 链表的节点数量大于等于树化阈值8",
      "autoResize": true,
