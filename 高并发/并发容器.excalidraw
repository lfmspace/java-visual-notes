    {
      "id": "iQl6eDyEQxjJvLw0g2EMm",
      "type": "text",
      "x": 2448.997862195424,
      "y": 8472.682891190561,
      "width": 899.8936313588259,
      "height": 75,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [
        "Jgi_3F_6UWwBU1kx4aitM",
        "gyIQ8q7K4MJDYHWRfKa2N",
        "QR25VRjpxJqo8G8V6lmBp",
        "_6OMo-GxwOgtXnkUmK6wT",
        "d4nLWB_aWwuTNaqgPhz7X",
        "ajuUIlaJES67Crmgb_VYd"
