      "lineHeight": 1.25
    },
    {
      "id": "NI_hO70aqA8cZ3ApYSYz4",
      "type": "text",
      "x": 1179.2109997254588,
      "y": 3804.6859255438053,
      "width": 781.5999145507812,
      "height": 25,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [
