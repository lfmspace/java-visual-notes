      "lineHeight": 1.25
    },
    {
      "id": "Zmx-ZndLCbS7vmguBnJPO",
      "type": "text",
      "x": 2950.8311955287572,
      "y": 3813.849557857229,
      "width": 899.8936313588259,
      "height": 75,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [
        "RdbotJGodSizgYG7T5WIu",
        "kKS1q7hDwBKTiwM8ZJx0_",
        "sVV7lcB_AF9Ii5_Ab8cJE",
        "KFYHliWlxUUGauZCNr3R8",
        "UvLS8v08leMdY6SW42y5R",
        "gTqcNimkDkbuhSG-EuQ9B",
        "yI4P1mxbo5oYIQXScdWeK"
      ],
      "frameId": null,
      "index": "c9bG",
      "roundness": null,
      "seed": 1114595967,
      "version": 624,
      "versionNonce": 808579736,
      "isDeleted": false,
      "boundElements": [],
      "updated": 1767944057738,
      "link": null,
      "locked": false,
      "text": "jdk1.8抛弃了Segments分段锁的方案，而是改用了和HashMap一样的结构操作，也就是数组 + 链表 +\n红黑树结构，比jdk1.7中的ConcurrentHashMap提高了效率，在并发方面，使用了cas + synchronized\n的方式保证数据的一致性",
      "fontSize": 20,
      "fontFamily": 6,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "jdk1.8抛弃了Segments分段锁的方案，而是改用了和HashMap一样的结构操作，也就是数组 + 链表 + 红黑树结构，比jdk1.7中的ConcurrentHashMap提高了效率，在并发方面，使用了cas + synchronized的方式保证数据的一致性",
      "autoResize": false,
      "lineHeight": 1.25
    },
