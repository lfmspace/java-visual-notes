      "locked": false,
      "text": "和 ArrayList 在使用方式方面很类似。",
      "fontSize": 20,
      "fontFamily": 6,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "和 ArrayList 在使用方式方面很类似。",
