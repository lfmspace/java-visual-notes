      "versionNonce": 407219608,
      "isDeleted": false,
      "boundElements": [],
      "updated": 1767944057738,
      "link": null,
      "locked": false,
      "text": "如果key已存在，则不进行插入并返回原有值；如果key不存在，则插入新值并返回 null。",
      "fontSize": 20,
      "fontFamily": 6,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "如果key已存在，则不进行插入并返回原有值；如果key不存在，则插入新值并返回 null。",
      "autoResize": true,
      "lineHeight": 1.25
    },
    {
