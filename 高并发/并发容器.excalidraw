      "text": "CopyOnWriteArrayList",
      "fontSize": 20,
      "fontFamily": 6,
      "textAlign": "center",
      "verticalAlign": "middle",
      "containerId": "mwyE_sAlCgjqR5gAopWo0",
      "originalText": "CopyOnWriteArrayList",
      "autoResize": true,
      "lineHeight": 1.25
    },
    {
      "id": "791u4DN2icmYUvY-D4BjZ",
      "type": "text",
      "x": -1161.7843219571819,
      "y": 3201.753403517743,
      "width": 1680.9476806085388,
      "height": 25,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [
        "2j6AWX3xj9qij90x5ynAu"
      ],
      "frameId": null,
      "index": "c9YS6",
      "roundness": null,
      "seed": 1066779775,
      "version": 483,
      "versionNonce": 71845352,
      "isDeleted": false,
      "boundElements": [],
      "updated": 1768059001225,
      "link": null,
      "locked": false,
      "text": "CopyOnWriteArrayList 是 Java 中的一种线程安全的 List，它是一个可变的数组，支持并发读和写。它通过在修改操作时创建底层数组的副本来实现线程安全，从而保证了并发访问的一致性。",
      "fontSize": 20,
      "fontFamily": 6,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "CopyOnWriteArrayList 是 Java 中的一种线程安全的 List，它是一个可变的数组，支持并发读和写。它通过在修改操作时创建底层数组的副本来实现线程安全，从而保证了并发访问的一致性。",
      "autoResize": false,
      "lineHeight": 1.25
    },
