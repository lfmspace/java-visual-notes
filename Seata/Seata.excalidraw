      "boundElements": [],
      "updated": 1775143332472,
      "link": null,
      "locked": false,
      "text": "ThreadPoolExecutor中提供了两种执行任务的方法：",
      "fontSize": 20,
      "fontFamily": 6,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "ThreadPoolExecutor中提供了两种执行任务的方法：",
      "autoResize": true,
      "lineHeight": 1.25
    },
    {
      "id": "J6CAy2sGRkikeuJ9SDUKg",
      "type": "text",
      "x": -4426.8085995417705,
      "y": 10374.143379504316,
      "width": 322.2396545410156,
      "height": 25,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [
        "rSR5Dr4n3yzI9S6XOi09x",
        "Ld3G-fgFq1R-X2icvYPrq"
      ],
      "frameId": null,
