      "updated": 1775143332472,
      "link": null,
      "locked": false,
      "text": "- RUNNING：会接收新任务并且会处理队列中的任务",
      "fontSize": 20,
      "fontFamily": 6,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "- RUNNING：会接收新任务并且会处理队列中的任务",
      "autoResize": true,
      "lineHeight": 1.25
    },
    {
      "id": "7Gwkul-OCv3CHF2ibYxx8",
      "type": "text",
      "x": -3154.690359820842,
      "y": 10447.459224653328,
      "width": 515.0799560546875,
      "height": 25,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 2,
