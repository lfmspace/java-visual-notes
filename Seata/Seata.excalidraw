    },
    {
      "id": "TWBn9BVAdwIhmrpCt3xj-",
      "type": "text",
      "x": -4337.266635343056,
      "y": 12024.882276235845,
      "width": 300,
      "height": 25,
      "angle": 0,
      "strokeColor": "#1e1e1e",
