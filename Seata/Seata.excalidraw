      "isDeleted": true,
      "boundElements": [],
      "updated": 1775143332472,
      "link": null,
      "locked": false,
      "text": "任务队列长度(workQueue)",
      "fontSize": 20,
      "fontFamily": 6,
      "textAlign": "center",
      "verticalAlign": "middle",
      "containerId": "2tfQ02LStLNzTSvWETB0a",
      "originalText": "任务队列长度(workQueue)",
      "autoResize": true,
      "lineHeight": 1.25
    },
    {
      "id": "q2ZApExM49eIGWA67Q16_",
      "type": "text",
      "x": -2254.2413896379567,
      "y": 9258.59882949471,
      "width": 510.43994140625,
      "height": 25,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [
        "fhC2E2d0PoYY0t6UhYPAq",
        "llsW3dZ67JK_ARZJQO0R3"
      ],
      "frameId": null,
      "index": "c9z1",
      "roundness": null,
      "seed": 1387025206,
      "version": 339,
      "versionNonce": 2053927207,
      "isDeleted": true,
      "boundElements": [],
      "updated": 1775143332472,
      "link": null,
      "locked": false,
      "text": "任务队列长度，也就是设计 阻塞队列 能缓存多少个任务。",
      "fontSize": 20,
      "fontFamily": 6,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "任务队列长度，也就是设计 阻塞队列 能缓存多少个任务。",
      "autoResize": true,
      "lineHeight": 1.25
    },
    {
      "id": "4WWQ_vhTQnNmnLZ5wbS8o",
      "type": "text",
      "x": -2254.2413896379567,
      "y": 9329.20478241643,
      "width": 797.3199462890625,
      "height": 50,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [
        "fhC2E2d0PoYY0t6UhYPAq",
        "llsW3dZ67JK_ARZJQO0R3"
      ],
      "frameId": null,
      "index": "c9z2",
      "roundness": null,
      "seed": 1522806250,
      "version": 376,
      "versionNonce": 95148233,
      "isDeleted": true,
      "boundElements": [],
      "updated": 1775143332472,
      "link": null,
      "locked": false,
      "text": "例如上面的场景中,核心线程数设计为10，单个任务执行时间为0.1秒，则队列长度可以设计\n为200 ;",
      "fontSize": 20,
      "fontFamily": 6,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "例如上面的场景中,核心线程数设计为10，单个任务执行时间为0.1秒，则队列长度可以设计为200 ;",
      "autoResize": false,
      "lineHeight": 1.25
    },
    {
      "id": "gf7QwtfqEjr4okwBkCK9u",
      "type": "rectangle",
      "x": -2254.2413896379567,
      "y": 9384.50775887729,
      "width": 290,
      "height": 35,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "#eebefa",
