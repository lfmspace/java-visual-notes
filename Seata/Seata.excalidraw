      "roundness": null,
      "seed": 1072478582,
      "version": 566,
      "versionNonce": 299531367,
      "isDeleted": true,
      "boundElements": [],
      "updated": 1775143332472,
      "link": null,
      "locked": false,
      "text": "1.void execute(Runnable command)",
      "fontSize": 20,
      "fontFamily": 6,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "1.void execute(Runnable command)",
