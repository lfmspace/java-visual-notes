      "locked": false
    },
    {
      "id": "0VPDkK5j0YYmcYeIGAMC6",
      "type": "text",
      "x": -2249.0413392839528,
      "y": 9223.29585303385,
      "width": 237.5998992919922,
      "height": 25,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
