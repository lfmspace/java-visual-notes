      "link": null,
      "locked": false,
      "text": "- SHUTDOWN：不会接收新任务并且会处理队列中的任务",
      "fontSize": 20,
      "fontFamily": 6,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "- SHUTDOWN：不会接收新任务并且会处理队列中的任务",
      "autoResize": true,
      "lineHeight": 1.25
    },
    {
      "id": "n9gWK94Y6daR81ELa6l_g",
      "type": "text",
      "x": -3154.690359820842,
      "y": 10477.638017169362,
      "width": 1145.9729024522621,
      "height": 25,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [
        "5knkOHAB9UC5u6DoT6GJz",
        "9D6_ud6-Dp770gIo6nlwP"
