      "link": null,
      "locked": false
    },
    {
      "id": "zpangA2LaekuL_szIpFmG",
      "type": "text",
      "x": -2248.9313310442067,
      "y": 9011.78097072955,
      "width": 228.3798828125,
      "height": 25,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [
        "fhC2E2d0PoYY0t6UhYPAq",
        "llsW3dZ67JK_ARZJQO0R3"
      ],
      "frameId": null,
      "index": "c9yu",
