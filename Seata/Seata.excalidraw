      "x": -2249.031306630144,
      "y": 9561.02264118159,
      "width": 267.579833984375,
      "height": 25,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [
        "fhC2E2d0PoYY0t6UhYPAq",
        "llsW3dZ67JK_ARZJQO0R3"
