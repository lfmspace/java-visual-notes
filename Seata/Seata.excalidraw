      "lineHeight": 1.25
    },
    {
      "id": "uz0TVmco2R59B-Yi8uWkC",
      "type": "rectangle",
      "x": -2254.2413896379567,
      "y": 9006.78097072955,
      "width": 239,
      "height": 35,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "#eebefa",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [
        "fhC2E2d0PoYY0t6UhYPAq",
        "llsW3dZ67JK_ARZJQO0R3"
      ],
      "frameId": null,
      "index": "c9yt",
      "roundness": {
        "type": 3
      },
      "seed": 2124956918,
      "version": 280,
      "versionNonce": 1633123495,
      "isDeleted": true,
      "boundElements": [
        {
          "id": "zpangA2LaekuL_szIpFmG",
