      "y": 10446.521412182054,
      "width": 941.1689955492433,
      "height": 25,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [
        "rSR5Dr4n3yzI9S6XOi09x",
        "Ld3G-fgFq1R-X2icvYPrq"
