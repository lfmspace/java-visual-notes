      "updated": 1775143332472,
      "link": null,
      "locked": false,
      "text": "线程池中的线程是如何关闭的？",
      "fontSize": 20,
      "fontFamily": 6,
      "textAlign": "center",
      "verticalAlign": "middle",
      "containerId": "41f_mPhcYMKvsGf30WLEX",
      "originalText": "线程池中的线程是如何关闭的？",
      "autoResize": true,
      "lineHeight": 1.25
    },
    {
      "id": "D218KvUNxkCUCHJ7OqCOw",
      "type": "text",
      "x": -4331.732066448819,
      "y": 11662.334961130657,
      "width": 679.9598388671875,
      "height": 25,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 2,
