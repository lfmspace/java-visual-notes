      "isDeleted": false,
      "boundElements": [],
      "updated": 1773147118414,
      "link": null,
      "locked": false,
      "text": "appendfsync no：从不 fsync ，将数据交给操作系统来处理。更快，也更不安全的选择。",
      "fontSize": 20,
      "fontFamily": 6,
      "textAlign": "center",
      "verticalAlign": "middle",
      "containerId": "PpSsgvDfEF5IZypAls7Gv",
      "originalText": "appendfsync no：从不 fsync ，将数据交给操作系统来处理。更快，也更不安全的选择。",
      "autoResize": true,
      "lineHeight": 1.25
    },
    {
      "id": "QlCNHSr3sIS0TtasLPWP-",
      "type": "rectangle",
      "x": 2127.540649491222,
