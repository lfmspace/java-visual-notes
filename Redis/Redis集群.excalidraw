      "locked": false,
      "text": "同时还会修改sentinel文件里之前配置的mymaster对应的6379端口，改为6380",
      "fontSize": 20,
      "fontFamily": 6,
      "textAlign": "left",
      "verticalAlign": "middle",
      "containerId": "35EXMQGyiNcbxnxCQgqKf",
      "originalText": "同时还会修改sentinel文件里之前配置的mymaster对应的6379端口，改为6380",
