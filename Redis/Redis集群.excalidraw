    {
      "id": "_N_LlJGVx9mw8li2GnvSz",
      "type": "text",
      "x": 1262.6775135292687,
      "y": 5136.658195584469,
      "width": 610.9597778320312,
      "height": 150,
      "angle": 0,
      "strokeColor": "#1e1e1e",
