      "status": "saved",
      "fileId": "b080096f6b8a83eaf6435c43aceaa9d06aec9e01",
      "scale": [
        1,
        1
      ],
      "crop": null
    },
    {
      "id": "BrzmEdfxpO0nrTAu-oe8T",
      "type": "rectangle",
      "x": 1333.1818181818185,
      "y": 9952.095888871996,
      "width": 1375.8956271165434,
      "height": 60,
      "angle": 0,
      "strokeColor": "#1e1e1e",
