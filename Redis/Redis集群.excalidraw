      "text": "server:\n  port: 8080\n\nspring:\n  redis:\n    database: 0\n    timeout: 3000\n    sentinel:    #哨兵模式\n      master: mymaster #主服务器所在集群名称\n     nodes: 192.168.0.60:26379,192.168.0.60:26380,192.168.0.60:26381\n   lettuce:\n      pool:\n        max-idle: 50\n        min-idle: 10\n        max-active: 100\n        max-wait: 1000",
      "fontSize": 20,
      "fontFamily": 6,
      "textAlign": "left",
      "verticalAlign": "middle",
      "containerId": "pu1Vex0lXpxspqnvKdisJ",
      "originalText": "server:\n  port: 8080\n\nspring:\n  redis:\n    database: 0\n    timeout: 3000\n    sentinel:    #哨兵模式\n      master: mymaster #主服务器所在集群名称\n     nodes: 192.168.0.60:26379,192.168.0.60:26380,192.168.0.60:26381\n   lettuce:\n      pool:\n        max-idle: 50\n        min-idle: 10\n        max-active: 100\n        max-wait: 1000",
      "autoResize": true,
      "lineHeight": 1.25
